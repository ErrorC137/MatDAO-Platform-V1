# =============================================================================
# MatDAO Frontend — v0 / Vercel / any Next.js host
# Copy to .env.local for local dev, or set in your hosting dashboard for production.
# =============================================================================

# --- Local development (defaults) ---
IP_ENGINE_URL=http://localhost:8765
TRL_SERVICES_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:8765
NEXT_PUBLIC_TRL_SERVICES_URL=http://localhost:3001

# --- Production (fill in your deployed service URLs) ---
# IP_ENGINE_URL=https://matdao-ip-engine.onrender.com
# TRL_SERVICES_URL=https://matdao-trl-services.onrender.com
# NEXT_PUBLIC_API_URL=https://matdao-ip-engine.onrender.com
# NEXT_PUBLIC_TRL_SERVICES_URL=https://matdao-trl-services.onrender.com

# Optional: public app URL for metadata / CORS on backends
# NEXT_PUBLIC_APP_URL=https://your-project.vercel.app
