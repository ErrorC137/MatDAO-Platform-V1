# =============================================================================
# MatDAO Frontend — v0 / Vercel / any Next.js host
# Copy to .env.local for local dev, or set in your hosting dashboard for production.
# =============================================================================

# --- Local development (defaults) ---
IP_ENGINE_URL=http://localhost:8765
TRL_SERVICES_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:8765
NEXT_PUBLIC_TRL_SERVICES_URL=http://localhost:3001

# --- Production (fill in your deployed service URLs) ---
# IP_ENGINE_URL=https://matdao-ip-engine.onrender.com
# TRL_SERVICES_URL=https://matdao-trl-services.onrender.com
# NEXT_PUBLIC_API_URL=https://matdao-ip-engine.onrender.com
# NEXT_PUBLIC_TRL_SERVICES_URL=https://matdao-trl-services.onrender.com

# Optional: public app URL for metadata / CORS on backends
# NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# MatDAO IP Engine backend (required for PDF/DOCX and IP Valuation)
# Start: cd matdao-ip-engine/backend && python -m uvicorn app.main:app --port 8765
# Production URL:
NEXT_PUBLIC_API_URL=https://matdao-backend-479f.onrender.com
IP_ENGINE_URL=https://matdao-backend-479f.onrender.com

# Supabase Configuration (required for authentication)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Pinata Configuration
PINATA_JWT=your_pinata_jwt_token
PINATA_GATEWAY=your_pinata_gateway

# WalletConnect Configuration (optional, for Web3 wallet connection)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Hardhat Configuration (for deployment)
PRIVATE_KEY=your_private_key
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key
