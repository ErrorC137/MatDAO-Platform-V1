{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "devCommand": "npm run dev",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_MATDAO_IPNFT_ADDRESS": "@next_public_matdao_ipnft_address",
    "NEXT_PUBLIC_MOCK_USDC_ADDRESS": "@next_public_mock_usdc_address",
    "NEXT_PUBLIC_MATDAO_ESCROW_ADDRESS": "@next_public_matdao_escrow_address",
    "NEXT_PUBLIC_MATDAO_SWAP_ADDRESS": "@next_public_matdao_swap_address",
    "NEXT_PUBLIC_MATDAO_IPT_ADDRESS": "@next_public_matdao_ipt_address",
    "NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID": "@next_public_walletconnect_project_id",
    "IP_ENGINE_URL": "@ip_engine_url",
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_ANON_KEY": "@supabase_anon_key",
    "PINATA_JWT": "@pinata_jwt",
    "PINATA_GATEWAY": "@pinata_gateway"
  }
}
